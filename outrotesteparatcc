def cria_tabela_processos(dados_processos: list[dict]):
    """
    Cria (ou recria) a tabela 'processos' no LanceDB.

    Campos esperados em cada item de dados_processos:
        id_processo (str), tributo (str), fase_atual (str),
        data_chave (str "YYYY-MM-DD"), valor_devido (float),
        devedor_anon (str), text (str), tipo (str)
    """
    texts   = [d["text"] for d in dados_processos]
    vectors = embed_model.encode(
        texts, normalize_embeddings=True, show_progress_bar=True
    ).tolist()

    table_processos = pa.table({
        "id":          list(range(len(dados_processos))),
        "id_processo": [d["id_processo"]  for d in dados_processos],
        "tributo":     [d["tributo"]      for d in dados_processos],
        "fase_atual":  [d["fase_atual"]   for d in dados_processos],
        "data_chave":  pa.array(
                           [d["data_chave"] for d in dados_processos],
                           type=pa.string()   # mantÃ©m como string ISO; converta se precisar de filtros temporais
                       ),
        "valor_devido":[d["valor_devido"] for d in dados_processos],
        "devedor_anon":[d["devedor_anon"] for d in dados_processos],
        "text":        texts,
        "tipo":        [d["tipo"]         for d in dados_processos],
        "full_text":   texts,
        "vector":      vectors,
    })

    if "processos" in db.table_names():
        db.drop_table("processos")

    tbl_proc = db.create_table("processos", data=table_processos)
    tbl_proc.create_index(metric="cosine")
    tbl_proc.create_fts_index("full_text", replace=True)
    print(f"âœ… Tabela 'processos' criada com {len(dados_processos)} registros.")
    return tbl_proc


def busca_processo(pergunta_texto: str, top_k: int = 5) -> list[dict]:
    """Busca semÃ¢ntica na tabela de processos."""
    tbl_proc   = db.open_table("processos")
    query_vec  = embed_model.encode(pergunta_texto, normalize_embeddings=True).tolist()
    resultados = tbl_proc.search(query_vec, vector_column_name="vector").limit(top_k).to_list()

    print(f"\nProcessos relacionados a: '{pergunta_texto}'")
    for r in resultados:
        print(f"  [{r['id_processo']}] {r['tributo']} | {r['fase_atual']} | R$ {r['valor_devido']:,.2f}")
        print(f"  {r['text'][:300]}...\n{'â”€'*60}")
    return resultados


