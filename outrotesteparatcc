def limpa_texto(texto: str) -> str:
    """Remove artefatos comuns de PDF (quebras de linha internas, espaÃ§os duplos etc.)."""
    texto = re.sub(r"(?<!\n)\n(?!\n)", " ", texto)       # quebras de linha simples â†’ espaÃ§o
    texto = re.sub(r" {2,}", " ", texto)                   # espaÃ§os mÃºltiplos
    texto = re.sub(r"\f", "\n\n", texto)                   # form feed â†’ parÃ¡grafo
    return texto.strip()


def extrai_norma(texto: str, nome_arquivo: str) -> str:
    """Tenta extrair identificaÃ§Ã£o da norma no cabeÃ§alho do PDF."""
    padrao = r"(lei\s+(?:complementar\s+)?|decreto(?:\s*-lei)?\s+|lc\s+)n?[ÂºÂ°]?\s*([\d.]+)\s*[,/de]+\s*(\d{4})"
    m = re.search(padrao, texto[:3000], re.I)
    if m:
        return m.group(0).upper().strip()
    return Path(nome_arquivo).stem.replace("_", " ").replace("-", " ").title()


